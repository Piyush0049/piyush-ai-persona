# Server Configuration
PORT=8000

# LLM Provider selection (Override provider: "bedrock", "openai", "gemini", or "ollama")
LLM_PROVIDER=bedrock

# AWS Bedrock Keys
# Get from: https://console.aws.amazon.com/iam/home#/security_credentials
AWS_ACCESS_KEY_ID=your_aws_access_key_here
AWS_SECRET_ACCESS_KEY=your_aws_secret_key_here
AWS_REGION=us-east-1

# AWS Bedrock Model Selection
# Options:
#   - us.amazon.nova-lite-v1:0 (Fast, cheap, good for basic queries)
#   - us.amazon.nova-pro-v1:0 (Better reasoning, Chain of Thought, recommended)
#   - us.anthropic.claude-3-haiku-20240307-v1:0 (Fast, accurate)
# Current recommendation: nova-pro-v1:0 for best Chain of Thought reasoning
AWS_BEDROCK_MODEL=us.amazon.nova-pro-v1:0

# Alternative API Keys (For OpenAI, Gemini, or Ollama fallback)
# OpenAI API Key - Get from: https://platform.openai.com/api-keys
OPENAI_API_KEY=

# Gemini API Key - Get from: https://makersuite.google.com/app/apikey
GEMINI_API_KEY=

# Ollama Local Setup (if running locally)
OLLAMA_URL=http://localhost:11434
OLLAMA_MODEL=qwen3:4b

# Ngrok Token (for public HTTPS tunnel)
# Get from: https://dashboard.ngrok.com/get-started/your-authtoken
NGROK_TOKEN=your_ngrok_token_here

# GitHub Token (Optional: For higher API rate limits - 5000 req/hr vs 60 req/hr)
# Get from: https://github.com/settings/tokens
# Scopes needed: Either leave all unchecked (for public repos) or just "public_repo"
# Benefits:
#   - Without token: 60 requests/hour
#   - With token: 5000 requests/hour
#   - Enables fetching all 61+ repositories without hitting rate limits
GITHUB_TOKEN=

# Calendar Settings (Optional: leave empty to use the local file booking database)
# Cal.com API - Get from: https://app.cal.com/settings/developer/api-keys
CAL_API_KEY=your_cal_api_key_here
CAL_EVENT_TYPE_ID=your_cal_event_type_id_here

# Google Calendar (Alternative to Cal.com)
# Setup: https://developers.google.com/calendar/api/quickstart/python
GOOGLE_CALENDAR_ID=your_email@gmail.com

# Vapi Web Calling Config (for voice interface)
# Get from: https://dashboard.vapi.ai
VAPI_PUBLIC_KEY=your_vapi_public_key_here
VAPI_ASSISTANT_ID=your_vapi_assistant_id_here

# ==============================================================================
# OPTIONAL CONFIGURATION FOR ADVANCED FEATURES
# ==============================================================================

# Deep Code Analysis (Optional: Enable to analyze repository source code)
# Set to "1" to clone repositories and extract API endpoints, algorithms, etc.
# Warning: This is slow and downloads all repositories locally
# DEEP_ANALYSIS=0

# RAG Configuration (Optional: Advanced tuning)
# Number of chunks to retrieve for normal queries (default: 4)
# RAG_NORMAL_CHUNKS=4

# Number of chunks to retrieve for comprehensive queries (default: 10)
# RAG_COMPREHENSIVE_CHUNKS=10

# ==============================================================================
# IMPORTANT NOTES
# ==============================================================================

# 1. AWS Bedrock Model Recommendation:
#    - For production: use us.amazon.nova-pro-v1:0 (best Chain of Thought reasoning)
#    - For development/testing: use us.amazon.nova-lite-v1:0 (cheaper, faster)
#
# 2. GitHub Token is HIGHLY RECOMMENDED:
#    - Increases rate limit from 60/hr to 5000/hr
#    - Required if you have 60+ repositories
#    - Only needs "public_repo" scope (or no scopes for public repos)
#
# 3. Calendar Integration:
#    - You can use EITHER Cal.com OR Google Calendar OR local JSON file
#    - Leave both empty to use local file-based booking (no API keys needed)
#
# 4. Vapi Voice Integration:
#    - Required only if you want voice calling feature
#    - Not needed for web chat interface
#
# 5. Cost Estimates (AWS Bedrock):
#    - Nova Lite: ~$0.0005 per chat session
#    - Nova Pro: ~$0.002 per chat session (recommended for quality)
#    - Voice calls: ~$0.45-1.10 per 5-minute call

# ==============================================================================
# QUICK START
# ==============================================================================

# 1. Copy this file to .env:
#    cp .env.example .env
#
# 2. Fill in at minimum:
#    - AWS_ACCESS_KEY_ID
#    - AWS_SECRET_ACCESS_KEY
#    - AWS_BEDROCK_MODEL (use us.amazon.nova-pro-v1:0)
#    - GITHUB_TOKEN (highly recommended)
#
# 3. Run the server:
#    python main.py
#
# 4. Visit: http://localhost:8000
