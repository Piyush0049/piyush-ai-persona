# Server Configuration
PORT=8000

# LLM Provider selection (Override provider: "bedrock", "openai", "gemini", or "ollama")
LLM_PROVIDER=

# AWS Bedrock Keys
AWS_ACCESS_KEY_ID=your_aws_access_key
AWS_SECRET_ACCESS_KEY=your_aws_secret_key
AWS_REGION=us-east-1
AWS_BEDROCK_MODEL=us.amazon.nova-lite-v1:0

# Alternative API Keys (For OpenAI, Gemini, or Ollama fallback)
OPENAI_API_KEY=your_openai_key
GEMINI_API_KEY=your_gemini_key
OLLAMA_URL=http://localhost:11434
OLLAMA_MODEL=qwen3:4b

# Ngrok Configuration (Optional)
NGROK_TOKEN=your_ngrok_token

# Vapi Web Calling Config (Optional - pre-fills credentials for visitors)
VAPI_PUBLIC_KEY=your_vapi_public_key
VAPI_ASSISTANT_ID=your_vapi_assistant_id

# Calendar Settings (Optional: leave empty to use the local file booking database)
CAL_API_KEY=your_cal_api_key
CAL_EVENT_TYPE_ID=your_cal_event_id
GOOGLE_CALENDAR_ID=your_google_calendar_id
